APP_ENV=development
DEBUG=true

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rasp_db
POSTGRES_USER=rasp_user
POSTGRES_PASSWORD=rasp_password

REDIS_HOST=redis
REDIS_PORT=6379

BACKEND_API_URL=http://localhost:8000/api
BACKEND_INTERNAL_API_URL=http://backend:8000/api

SESSION_SECRET_KEY=change-me-in-production
SESSION_COOKIE_NAME=raspsystem_session
SESSION_MAX_AGE=604800
SESSION_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=

FRONTEND_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
CSRF_TRUSTED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
API_DOCS_ENABLED=true
ALLOW_ORIGINLESS_UNSAFE_REQUESTS=true

LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
PASSWORD_CHANGE_RATE_LIMIT_ATTEMPTS=5
PASSWORD_CHANGE_RATE_LIMIT_WINDOW_SECONDS=600

RASPYX_USERNAME=
RASPYX_PASSWORD=

# Schedule Service DB
SCHEDULE_DB_HOST=postgres-schedule
SCHEDULE_DB_PORT=5432
SCHEDULE_DB_USER=schedule_user
SCHEDULE_DB_PASSWORD=schedule_password
SCHEDULE_DB_NAME=schedule_db

# JWT
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
