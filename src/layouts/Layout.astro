---
import ToastProvider from '../components/ToastProvider.vue';

export interface Props {
    title: string;
}

const { title } = Astro.props;
const currentYear = new Date().getFullYear();
const csrfToken = Astro.locals.csrfToken ?? "";
---

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="backend-csrf-token" content={csrfToken} />
    <title>{title}</title>
    <script is:inline>
        const theme = (() => {
            if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
            }
            if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
            }
            return 'light';
        })();

        if (theme === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
</head>

<body class="min-h-screen font-sans antialiased flex flex-col text-slate-900 dark:text-slate-100">
<div class="page-bg" aria-hidden="true"></div>

<div class="page-orbits" aria-hidden="true">
    <svg viewBox="0 0 1600 1200" preserveAspectRatio="none">
        <defs>
            <linearGradient id="orbitStrong" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="rgba(102, 146, 255, 0.00)" />
                <stop offset="30%" stop-color="rgba(102, 146, 255, 0.10)" />
                <stop offset="55%" stop-color="rgba(102, 146, 255, 0.34)" />
                <stop offset="75%" stop-color="rgba(102, 146, 255, 0.18)" />
                <stop offset="100%" stop-color="rgba(102, 146, 255, 0.00)" />
            </linearGradient>

            <linearGradient id="orbitSoft" x1="1" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(121, 166, 255, 0.00)" />
                <stop offset="38%" stop-color="rgba(121, 166, 255, 0.08)" />
                <stop offset="65%" stop-color="rgba(121, 166, 255, 0.18)" />
                <stop offset="100%" stop-color="rgba(121, 166, 255, 0.00)" />
            </linearGradient>

            <linearGradient id="orbitGlow" x1="0" y1="1" x2="1" y2="0">
                <stop offset="0%" stop-color="rgba(121, 166, 255, 0.00)" />
                <stop offset="50%" stop-color="rgba(121, 166, 255, 0.14)" />
                <stop offset="100%" stop-color="rgba(121, 166, 255, 0.00)" />
            </linearGradient>
        </defs>

        <g class="orbit-group orbit-group-a">
            <path class="orbit orbit-soft" d="M -120 1040 C 180 860, 430 760, 710 670 C 980 584, 1210 472, 1540 210" />
            <path class="orbit orbit-glow" d="M -180 1100 C 140 900, 410 780, 730 690 C 1010 610, 1240 500, 1600 170" />
        </g>

        <g class="orbit-group orbit-group-b">
            <path class="orbit orbit-strong" d="M 900 1280 C 880 1020, 950 820, 1130 660 C 1290 518, 1450 418, 1710 360" />
        </g>

        <g class="orbit-group orbit-group-c">
            <path class="orbit orbit-soft" d="M 280 -140 C 430 30, 560 180, 660 360 C 770 560, 840 790, 900 1280" />
        </g>

        <g class="orbit-group orbit-group-d">
            <path class="orbit orbit-faint" d="M -140 430 C 160 390, 430 340, 730 170 C 1020 5, 1260 -110, 1540 -70" />
        </g>
    </svg>
</div>

<header class="site-header">
    <a href="/" class="site-brand">
        <img
                src="/image/logo-light.jpg"
                alt="Московский Политех"
                class="site-brand-logo logo-light"
        />

        <img
                src="/image/logo-dark.png"
                alt="Московский Политех"
                class="site-brand-logo logo-dark"
        />
    </a>

    <div class="site-actions">
        <slot name="nav-actions" />

        <button
                id="theme-toggle"
                class="site-theme-button"
                title="Переключить тему"
                aria-label="Переключить тему"
        >
            <svg id="theme-toggle-dark-icon" class="hidden w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
            </svg>

            <svg id="theme-toggle-light-icon" class="hidden w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="4.8" fill="currentColor" />
                <g stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                    <line x1="12" y1="2.4" x2="12" y2="5" />
                    <line x1="12" y1="19" x2="12" y2="21.6" />
                    <line x1="2.4" y1="12" x2="5" y2="12" />
                    <line x1="19" y1="12" x2="21.6" y2="12" />
                    <line x1="5.2" y1="5.2" x2="7" y2="7" />
                    <line x1="17" y1="17" x2="18.8" y2="18.8" />
                    <line x1="5.2" y1="18.8" x2="7" y2="17" />
                    <line x1="17" y1="7" x2="18.8" y2="5.2" />
                </g>
            </svg>
        </button>
    </div>
</header>

<main class="flex-grow relative z-10 transition-colors duration-300">
    <slot />
</main>

<ToastProvider client:load />

<footer class="relative z-10 mt-auto px-3 pb-3 sm:px-4 sm:pb-4">
    <div class="mx-auto max-w-7xl">
        <div class="footer-shell px-4 py-5 sm:px-6">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 text-[11px]">
                <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-2 sm:gap-4 text-slate-600 dark:text-white/45">
                    <span>&copy; {currentYear} Факультет информационных технологий МПУ</span>
                    <span class="hidden sm:inline opacity-30 text-slate-400 dark:text-white/30">&middot;</span>
                    <a href="tel:+74952230523" class="footer-link">+7 495 223-05-23, доб. 1709</a>
                    <a href="mailto:fit@mospolytech.ru" class="footer-link">fit@mospolytech.ru</a>
                </div>

                <span class="flex items-center gap-1.5 text-slate-600 dark:text-white/50">
                    Разработано
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" class="text-sky-600 dark:text-sky-400">
                        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                    </svg>
                    <a href="https://t.me/edducon" target="_blank" class="font-semibold text-slate-700 dark:text-white hover:text-sky-700 dark:hover:text-sky-300 transition-colors">
                        @edducon
                    </a>
                </span>
            </div>
        </div>
    </div>
</footer>

<script is:inline>
    window.__BACKEND_CSRF_TOKEN__ = document
        .querySelector('meta[name="backend-csrf-token"]')
        ?.getAttribute('content') ?? '';

    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
    const themeToggleBtn = document.getElementById('theme-toggle');

    function updateThemeIcon() {
        const isDark = document.documentElement.classList.contains('dark');

        if (isDark) {
            themeToggleLightIcon?.classList.remove('hidden');
            themeToggleDarkIcon?.classList.add('hidden');
        } else {
            themeToggleDarkIcon?.classList.remove('hidden');
            themeToggleLightIcon?.classList.add('hidden');
        }
    }

    updateThemeIcon();

    themeToggleBtn?.addEventListener('click', function () {
        const toggleTheme = () => {
            const isDark = document.documentElement.classList.contains('dark');

            if (isDark) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }

            updateThemeIcon();
        };

        if (!document.startViewTransition) {
            toggleTheme();
            return;
        }

        const rect = themeToggleBtn.getBoundingClientRect();
        const x = rect.left + rect.width / 2;
        const y = rect.top + rect.height / 2;

        const endRadius = Math.hypot(
            Math.max(x, innerWidth - x),
            Math.max(y, innerHeight - y)
        );

        const transition = document.startViewTransition(toggleTheme);

        transition.ready.then(() => {
            document.documentElement.animate(
                {
                    clipPath: [
                        `circle(0px at ${x}px ${y}px)`,
                        `circle(${endRadius}px at ${x}px ${y}px)`
                    ]
                },
                {
                    duration: 520,
                    easing: 'ease-in-out',
                    pseudoElement: '::view-transition-new(root)'
                }
            );
        });
    });
</script>

<style is:global>
    :root {
        color-scheme: light;
        --page-bg: #ffffff;
        --panel-bg: rgba(255, 255, 255, 0.74);
        --panel-bg-strong: rgba(255, 255, 255, 0.86);
        --panel-muted: rgba(247, 249, 252, 0.78);
        --panel-border: rgba(103, 112, 130, 0.14);
        --panel-border-strong: rgba(63, 73, 92, 0.18);
        --panel-shadow: 0 8px 24px rgba(33, 38, 45, 0.06), 0 1px 3px rgba(33, 38, 45, 0.05);
        --panel-shadow-strong: 0 14px 30px rgba(33, 38, 45, 0.08), 0 2px 6px rgba(33, 38, 45, 0.06);
        --text-main: #18202d;
        --text-soft: rgba(24, 32, 45, 0.68);
        --text-faint: rgba(24, 32, 45, 0.45);
        --accent: #5a7aa5;
        --accent-strong: #3b5c86;
        --accent-soft: rgba(90, 122, 165, 0.12);
        --danger: #ba4747;
        --success: #2b7456;
        --poly-red: #ef3340;
        --poly-red-dark: #d92d39;
    }

    html.dark {
        color-scheme: dark;
        --page-bg: linear-gradient(180deg, #11161c 0%, #161b22 48%, #0f141b 100%);
        --panel-bg: rgba(20, 26, 35, 0.78);
        --panel-bg-strong: rgba(23, 29, 37, 0.88);
        --panel-muted: rgba(27, 34, 45, 0.72);
        --panel-border: rgba(214, 223, 235, 0.1);
        --panel-border-strong: rgba(214, 223, 235, 0.16);
        --panel-shadow: 0 10px 28px rgba(0, 0, 0, 0.22), 0 1px 4px rgba(0, 0, 0, 0.16);
        --panel-shadow-strong: 0 16px 36px rgba(0, 0, 0, 0.28), 0 2px 8px rgba(0, 0, 0, 0.2);
        --text-main: #eef2f7;
        --text-soft: rgba(238, 242, 247, 0.7);
        --text-faint: rgba(238, 242, 247, 0.45);
        --accent: #7ea1cf;
        --accent-strong: #94b5df;
        --accent-soft: rgba(126, 161, 207, 0.18);
        --danger: #e07a7a;
        --success: #70c29a;
    }

    html,
    body {
        min-height: 100%;
    }

    body {
        background: var(--page-bg);
        color: var(--text-main);
        transition: background-color 0.3s ease, color 0.3s ease;
        overflow-x: clip;
    }

    .page-bg,
    .page-orbits {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .page-orbits {
        overflow: hidden;
        opacity: 1;
    }

    .page-orbits svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    .orbit-group {
        transform-origin: center;
        will-change: transform, opacity;
    }

    .orbit-group-a {
        animation: orbitFloatA 15s ease-in-out infinite alternate;
    }

    .orbit-group-b {
        animation: orbitFloatB 19s ease-in-out infinite alternate;
    }

    .orbit-group-c {
        animation: orbitFloatC 17s ease-in-out infinite alternate;
    }

    .orbit-group-d {
        animation: orbitFloatD 21s ease-in-out infinite alternate;
    }

    .orbit {
        fill: none;
        vector-effect: non-scaling-stroke;
        stroke-linecap: round;
        stroke-linejoin: round;
        will-change: stroke-dashoffset, opacity, transform;
    }

    .orbit-strong {
        stroke: url(#orbitStrong);
        stroke-width: 16;
        opacity: 0.9;
        filter: blur(0.2px);
        stroke-dasharray: 220 32;
        animation: orbitDashStrong 14s linear infinite;
    }

    .orbit-soft {
        stroke: url(#orbitSoft);
        stroke-width: 10;
        opacity: 0.68;
        filter: blur(0.3px);
        stroke-dasharray: 160 28;
        animation: orbitDashSoft 18s linear infinite;
    }

    .orbit-glow {
        stroke: url(#orbitGlow);
        stroke-width: 36;
        opacity: 0.16;
        filter: blur(16px);
        stroke-dasharray: 260 40;
        animation: orbitDashGlow 24s linear infinite;
    }

    .orbit-faint {
        stroke: rgba(130, 166, 235, 0.12);
        stroke-width: 8;
        opacity: 0.5;
        filter: blur(0.4px);
        stroke-dasharray: 90 24;
        animation: orbitDashFaint 20s linear infinite;
    }

    html.dark .orbit-strong {
        opacity: 0.7;
    }

    html.dark .orbit-soft {
        opacity: 0.52;
    }

    html.dark .orbit-glow {
        opacity: 0.14;
    }

    html.dark .orbit-faint {
        stroke: rgba(148, 181, 223, 0.10);
        opacity: 0.4;
    }

    .poly-header {
        min-height: 76px;
        border-radius: 26px;
        border: 1px solid var(--panel-border);
        background: rgba(255, 255, 255, 0.84);
        box-shadow: var(--panel-shadow);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 14px 18px;
    }

    html.dark .poly-header {
        background: rgba(17, 22, 28, 0.84);
    }

    .poly-brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        color: var(--text-main);
        text-decoration: none;
        min-width: 0;
    }

    .poly-logo {
        width: 48px;
        height: 48px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--panel-bg-strong);
        border: 1px solid var(--panel-border);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .poly-brand-text {
        display: flex;
        flex-direction: column;
        font-size: 18px;
        line-height: 0.95;
        font-weight: 900;
        letter-spacing: 0.045em;
        text-transform: uppercase;
    }

    .poly-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

    .poly-actions > a {
        min-height: 48px !important;
        border-radius: 18px !important;
        border: 0 !important;
        background: var(--poly-red) !important;
        color: #ffffff !important;
        padding: 0 24px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: 13px !important;
        font-weight: 900 !important;
        letter-spacing: 0.08em !important;
        text-transform: uppercase !important;
        box-shadow: 0 10px 22px rgba(239, 51, 64, 0.18) !important;
        transition: transform 0.22s ease, background-color 0.22s ease, box-shadow 0.22s ease !important;
    }

    .poly-actions > a:hover {
        background: var(--poly-red-dark) !important;
        transform: translateY(-1px);
        box-shadow: 0 14px 28px rgba(239, 51, 64, 0.24) !important;
    }

    .poly-theme-button {
        width: 48px;
        height: 48px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text-main);
        background: var(--panel-muted);
        border: 1px solid var(--panel-border);
        transition: transform 0.22s ease, color 0.22s ease, border-color 0.22s ease, background-color 0.22s ease, box-shadow 0.22s ease;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .poly-theme-button:hover {
        transform: translateY(-1px);
        color: var(--text-main);
        border-color: var(--panel-border-strong);
        box-shadow: 0 8px 18px rgba(33, 38, 45, 0.08);
    }

    .footer-shell {
        border: 1px solid var(--panel-border);
        background: var(--panel-bg);
        box-shadow: var(--panel-shadow);
        border-radius: 18px;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .footer-link {
        color: inherit;
        transition: color 0.2s ease;
    }

    .footer-link:hover {
        color: var(--accent-strong);
    }

    ::view-transition-old(root),
    ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
    }

    ::view-transition-old(root) {
        z-index: 1;
    }

    ::view-transition-new(root) {
        z-index: 2;
    }

    .hide-scrollbar {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }

    .academic-panel {
        border: 1px solid var(--panel-border);
        background: var(--panel-bg);
        box-shadow: var(--panel-shadow);
        border-radius: 22px;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .academic-section {
        border: 1px solid var(--panel-border);
        background: var(--panel-bg-strong);
        box-shadow: var(--panel-shadow);
        border-radius: 18px;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .academic-muted {
        background: var(--panel-muted);
        border: 1px solid var(--panel-border);
        border-radius: 22px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .academic-kicker {
        font-size: 11px;
        line-height: 1;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 800;
        color: var(--text-faint);
    }

    .academic-title {
        letter-spacing: -0.04em;
        font-weight: 900;
    }

    .tnum {
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    * {
        transition: background-color 0.22s ease, border-color 0.22s ease, color 0.22s ease, box-shadow 0.22s ease;
    }

    @keyframes orbitDashStrong {
        from { stroke-dashoffset: 0; }
        to { stroke-dashoffset: -504; }
    }

    @keyframes orbitDashSoft {
        from { stroke-dashoffset: 0; }
        to { stroke-dashoffset: 376; }
    }

    @keyframes orbitDashGlow {
        from { stroke-dashoffset: 0; }
        to { stroke-dashoffset: -600; }
    }

    @keyframes orbitDashFaint {
        from { stroke-dashoffset: 0; }
        to { stroke-dashoffset: 228; }
    }

    @keyframes orbitFloatA {
        from { transform: translate3d(0, 0, 0) scale(1); }
        to { transform: translate3d(24px, -14px, 0) scale(1.018); }
    }

    @keyframes orbitFloatB {
        from { transform: translate3d(0, 0, 0) scale(1); }
        to { transform: translate3d(-20px, 16px, 0) scale(1.02); }
    }

    @keyframes orbitFloatC {
        from {
            transform: translate3d(0, 0, 0);
            opacity: 0.52;
        }
        to {
            transform: translate3d(16px, -20px, 0);
            opacity: 0.72;
        }
    }

    @keyframes orbitFloatD {
        from {
            transform: translate3d(0, 0, 0);
            opacity: 0.38;
        }
        to {
            transform: translate3d(-16px, 10px, 0);
            opacity: 0.56;
        }
    }

    @media (max-width: 768px) {
        .page-orbits {
            opacity: 0.78;
        }

        .orbit-strong {
            stroke-width: 12;
        }

        .orbit-soft,
        .orbit-faint {
            stroke-width: 7;
        }

        .orbit-glow {
            stroke-width: 24;
        }

        .poly-header {
            min-height: 66px;
            border-radius: 22px;
            padding: 10px 12px;
        }

        .poly-logo {
            width: 42px;
            height: 42px;
        }

        .poly-brand-text {
            font-size: 13px;
        }

        .poly-actions {
            gap: 8px;
        }

        .poly-actions > a {
            min-height: 42px !important;
            padding: 0 16px !important;
            border-radius: 16px !important;
            font-size: 12px !important;
        }

        .poly-theme-button {
            width: 42px;
            height: 42px;
            border-radius: 16px;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .orbit-group-a,
        .orbit-group-b,
        .orbit-group-c,
        .orbit-group-d,
        .orbit-strong,
        .orbit-soft,
        .orbit-glow,
        .orbit-faint {
            animation: none !important;
        }
    }
    .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        width: 100%;
        padding: 24px 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .site-brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        color: var(--text-main);
    }

    .site-brand-logo {
        width: 46px;
        height: 46px;
        object-fit: contain;
    }

    .site-brand-text {
        font-size: 18px;
        font-weight: 900;
        letter-spacing: -0.03em;
        text-transform: uppercase;
    }

    .site-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .site-theme-button {
        width: 46px;
        height: 46px;
        border-radius: 999px;
        border: 1px solid var(--panel-border);
        background: rgba(255, 255, 255, 0.76);
        color: var(--text-main);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(14px);
    }

    html.dark .site-theme-button {
        background: rgba(23, 29, 37, 0.76);
    }

    @media (max-width: 640px) {
        .site-header {
            padding: 18px 18px;
        }

        .site-brand-logo {
            width: 40px;
            height: 40px;
        }

        .site-brand-text {
            font-size: 14px;
        }

        .site-actions > a,
        .site-theme-button {
            height: 40px !important;
        }

        .site-actions > a {
            padding: 0 16px !important;
            font-size: 12px !important;
        }

        .site-theme-button {
            width: 40px;
