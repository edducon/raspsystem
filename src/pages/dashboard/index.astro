---
import Layout from '../../layouts/Layout.astro';
import RetakeScheduler from '../../components/RetakeScheduler.vue';
import TeacherBoard from '../../components/TeacherBoard.vue';
import { db } from '../../db';
import { teachersLocal, users, retakes, retakeTeachers } from '../../db/schema';
import { RaspyxAPI } from '../../lib/api-client';
import { eq } from 'drizzle-orm';

export const prerender = false;

if (!Astro.locals.session) {
    return Astro.redirect('/login');
}

const sessionUser = Astro.locals.user;
const [dbUser] = await db.select().from(users).where(eq(users.id, sessionUser.id));

const isAdmin = dbUser.role === 'ADMIN';
const isEmployee = dbUser.role === 'EMPLOYEE';
const isTeacher = dbUser.role === 'TEACHER';

const canSchedule = isAdmin || isEmployee;
const hasOwnSchedule = !!dbUser.teacherUuid;

const urlTab = Astro.url.searchParams.get('tab');
const defaultTab = hasOwnSchedule ? 'schedule' : 'retakes';
const activeTab = urlTab || defaultTab;

let apiGroups = [];
let apiSubjects = [];
let localTeachers = [];

if (canSchedule) {
    try {
        const groupsRes = await RaspyxAPI.getGroups();
        const subjectsRes = await RaspyxAPI.getSubjects();
        if (groupsRes?.result) apiGroups = groupsRes.result;
        if (subjectsRes?.result) apiSubjects = subjectsRes.result;
    } catch (e) {
        console.error("Ошибка загрузки справочников API", e);
    }
    localTeachers = await db.select().from(teachersLocal).orderBy(teachersLocal.fullName);
}

let teacherRetakesFormatted = [];
let teacherBaseSchedule = null;
let teacherFullName = '';

if (hasOwnSchedule) {
    const [tLocal] = await db.select().from(teachersLocal).where(eq(teachersLocal.uuid, dbUser.teacherUuid));
    if (tLocal) {
        teacherFullName = tLocal.fullName;
        try {
            const schedRes = await RaspyxAPI.getTeacherSchedule(teacherFullName);
            if (schedRes?.result) teacherBaseSchedule = schedRes.result;
        } catch (e) {
            console.error("Ошибка загрузки расписания преподавателя", e);
        }
    }

    const myRetakes = await db.select({
        id: retakes.id,
        groupUuid: retakes.groupUuid,
        subjectUuid: retakes.subjectUuid,
        date: retakes.date,
        timeSlots: retakes.timeSlots,
        room: retakes.roomUuid,
        link: retakes.link,
        attemptNumber: retakes.attemptNumber,
        myRole: retakeTeachers.role
    })
        .from(retakes)
        .innerJoin(retakeTeachers, eq(retakes.id, retakeTeachers.retakeId))
        .where(eq(retakeTeachers.teacherUuid, dbUser.teacherUuid));

    try {
        const groupsRes = await RaspyxAPI.getGroups();
        const subjectsRes = await RaspyxAPI.getSubjects();
        const groups = groupsRes?.result || [];
        const subjects = subjectsRes?.result || [];

        teacherRetakesFormatted = myRetakes.map(r => ({
            ...r,
            groupName: groups.find((g: any) => g.uuid === r.groupUuid)?.number || 'Неизвестная группа',
            subjectName: subjects.find((s: any) => s.uuid === r.subjectUuid)?.name || 'Неизвестный предмет',
        }));
    } catch (e) {}
}

let roleBadge = 'ПРЕПОДАВАТЕЛЬ';
let roleClass = 'bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-300';

if (isAdmin) {
    roleBadge = 'АДМИН';
    roleClass = 'bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-400';
} else if (isEmployee) {
    roleBadge = 'СОТРУДНИК КАФЕДРЫ (ДИСПЕТЧЕР)';
    roleClass = 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-800 dark:text-emerald-400';
}
---

<Layout title="Рабочий стол">
    <!-- Sticky header -->
    <div class="sticky top-0 z-40 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 shadow-sm transition-colors">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center gap-4">
            <div class="flex items-center gap-3 min-w-0">
                <div class="w-8 h-8 bg-slate-900 dark:bg-indigo-600 text-white flex items-center justify-center font-bold text-sm rounded-lg shrink-0">П</div>
                <div class="min-w-0">
                    <div class="text-sm font-bold text-slate-900 dark:text-white truncate">
                        {dbUser?.username}
                        {teacherFullName && <span class="font-normal text-slate-400 dark:text-slate-500 ml-1.5">— {teacherFullName}</span>}
                    </div>
                    <span class={`inline-block px-2 py-0.5 rounded text-xs font-bold ${roleClass}`}>{roleBadge}</span>
                </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
                {isAdmin && (
                    <a href="/admin" class="text-xs font-medium text-indigo-700 dark:text-indigo-300 hover:text-indigo-800 dark:hover:text-indigo-200 bg-indigo-50 dark:bg-indigo-900/50 border border-indigo-100 dark:border-indigo-800/50 py-2 px-3 rounded-xl shadow-sm transition-colors">
                        Админка
                    </a>
                )}
                <a href="/profile" class="text-xs font-medium text-slate-700 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 py-2 px-3 rounded-xl shadow-sm transition-colors">
                    Профиль
                </a>
                <button id="logout-btn" class="text-xs font-medium text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 py-2 px-3 rounded-xl shadow-sm transition-colors">
                    Выйти
                </button>
            </div>
        </div>
    </div>

    <main class="min-h-screen pt-6 pb-12 px-4 sm:px-6 lg:px-8 flex flex-col">
        <div class="max-w-7xl mx-auto w-full flex-grow">

            {(hasOwnSchedule && canSchedule) && (
                    <div class="mb-6 overflow-x-auto hide-scrollbar">
                        <div class="flex p-1 bg-slate-100 dark:bg-slate-800/60 rounded-xl w-max min-w-full sm:min-w-0 border border-slate-200 dark:border-slate-700/50">
                            <a href="?tab=schedule" class={`px-5 py-2 text-sm font-medium rounded-lg transition-all whitespace-nowrap ${activeTab === 'schedule' ? 'bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200'}`}>
                                Моё расписание
                            </a>
                            <a href="?tab=retakes" class={`px-5 py-2 text-sm font-medium rounded-lg transition-all whitespace-nowrap ${activeTab === 'retakes' ? 'bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200'}`}>
                                Назначение пересдач
                            </a>
                        </div>
                    </div>
            )}

            {(activeTab === 'retakes' && canSchedule) && (
                    <RetakeScheduler
                            client:load
                            groups={apiGroups}
                            subjects={apiSubjects}
                            teachers={localTeachers}
                            currentUser={{
                                id: dbUser.id,
                                role: dbUser.role,
                                departmentIds: dbUser.departmentIds
                            }}
                    />
            )}

            {(activeTab === 'schedule' && hasOwnSchedule) && (
                    <TeacherBoard
                            client:load
                            teacherFullName={teacherFullName}
                            retakes={teacherRetakesFormatted}
                            baseSchedule={teacherBaseSchedule}
                    />
            )}

        </div>
    </main>

    <script>
        import { actions } from 'astro:actions';
        const logoutBtn = document.querySelector('#logout-btn');
        logoutBtn?.addEventListener('click', async () => {
            await actions.auth.logout();
            window.location.href = '/';
        });
    </script>
</Layout>