---
import Layout from '../../layouts/Layout.astro';
import RetakeScheduler from '../../components/RetakeScheduler.vue';
import TeacherBoard from '../../components/TeacherBoard.vue';
import { fetchBackendFromServer } from '../../lib/backend-api';
import { getPublicBackendApiUrl } from '../../lib/backend-auth';
import { cleanSubjectName } from '../../lib/subjectNorm';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect('/login');
}

if (user.mustChangePassword) {
    return Astro.redirect('/profile?forcePasswordChange=1');
}

const isAdmin = user.role === 'ADMIN';
const isEmployee = user.role === 'EMPLOYEE';
const canSchedule = isAdmin || isEmployee;
const hasOwnSchedule = !!user.teacherUuid;
const activeTab = Astro.url.searchParams.get('tab') || (hasOwnSchedule ? 'schedule' : 'retakes');

let apiGroups = [];
let apiSubjects = [];
let localTeachers = [];

if (canSchedule || hasOwnSchedule) {
    try {
        const dictionaries = await fetchBackendFromServer('/schedule-data/dictionaries', {}, Astro.request);
        apiGroups = dictionaries?.groups ?? [];
        apiSubjects = dictionaries?.subjects ?? [];
    } catch (error) {
        console.error('Failed to load dictionaries', error);
    }
}

if (canSchedule) {
    try {
        localTeachers = await fetchBackendFromServer('/teacher-directory/', {}, Astro.request);
    } catch (error) {
        console.error('Failed to load teacher directory', error);
    }
}

let teacherFullName = user.fullName || user.username;
let teacherBaseSchedule = null;
let teacherRetakesFormatted = [];

if (hasOwnSchedule) {
    try {
        const teacherSchedule = user.teacherUuid
            ? await fetchBackendFromServer(`/schedule-data/teacher/${user.teacherUuid}`, {}, Astro.request)
            : null;

        if (teacherSchedule) {
            teacherFullName = teacherSchedule.teacherFullName;
            teacherBaseSchedule = teacherSchedule.schedule ?? null;
        }

        const myRetakes = await fetchBackendFromServer('/retakes/mine', {}, Astro.request);

        teacherRetakesFormatted = myRetakes.map((retake: any) => ({
            ...retake,
            groupName: apiGroups.find((group: any) => group.uuid === retake.groupUuid)?.number || 'Неизвестная группа',
            subjectName: cleanSubjectName(
                retake.subjectName || apiSubjects.find((subject: any) => subject.uuid === retake.subjectUuid)?.name || 'Неизвестная дисциплина',
            ),
        }));
    } catch (error) {
        console.error('Failed to load teacher retakes', error);
    }
}

const roleLabel = isAdmin ? 'Администратор' : isEmployee ? 'Сотрудник' : 'Преподаватель';
const backendApiUrl = getPublicBackendApiUrl();
const csrfToken = Astro.locals.csrfToken ?? '';
---
<Layout title="Рабочий кабинет">
    <Fragment slot="nav-center">
        <div class="hidden sm:flex items-center gap-2 min-w-0">
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300 truncate">
                {teacherFullName}
            </span>
            <span class="inline-flex px-2.5 py-1 rounded-xl text-[10px] font-bold uppercase tracking-[0.18em] bg-[var(--accent-soft)] text-[var(--accent-strong)] border border-[var(--panel-border)]">
                {roleLabel}
            </span>
        </div>
    </Fragment>

    <Fragment slot="nav-actions">
        {isAdmin && (
            <a href="/admin" class="inline-flex items-center justify-center h-10 px-4 rounded-2xl border border-slate-300/80 dark:border-white/10 bg-[var(--panel-bg-strong)] dark:bg-[var(--panel-muted)] text-slate-800 dark:text-white text-sm font-semibold hover:border-slate-400 dark:hover:border-white/20 transition">
                Админка
            </a>
        )}
        <a href="/profile" class="inline-flex items-center justify-center h-10 px-4 rounded-2xl border border-slate-300/80 dark:border-white/10 bg-[var(--panel-bg-strong)] dark:bg-[var(--panel-muted)] text-slate-700 dark:text-slate-200 text-sm font-semibold hover:border-slate-400 dark:hover:border-white/20 transition">
            Профиль
        </a>
        <button id="logout-btn" class="inline-flex items-center justify-center h-10 px-4 rounded-2xl border border-slate-300/80 dark:border-white/10 bg-[var(--panel-bg-strong)] dark:bg-[var(--panel-muted)] text-slate-700 dark:text-slate-200 text-sm font-semibold hover:border-slate-400 dark:hover:border-white/20 transition">
            Выйти
        </button>
    </Fragment>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-5">
        {(hasOwnSchedule && canSchedule) && (
            <div class="overflow-x-auto hide-scrollbar">
                <div class="inline-flex gap-2 rounded-[24px] border border-[var(--panel-border)] bg-[var(--panel-bg)] p-2 shadow-[var(--panel-shadow)]">
                    <a
                        href="?tab=schedule"
                        class={`px-5 py-2.5 text-sm font-semibold rounded-2xl transition whitespace-nowrap border ${activeTab === 'schedule'
                            ? 'bg-slate-900 text-white border-slate-900 dark:bg-white dark:text-slate-900 dark:border-white'
                            : 'bg-transparent text-slate-600 dark:text-slate-300 border-transparent hover:border-[var(--panel-border)] hover:bg-[var(--panel-muted)]'}`}
                    >
                        Моё расписание
                    </a>
                    <a
                        href="?tab=retakes"
                        class={`px-5 py-2.5 text-sm font-semibold rounded-2xl transition whitespace-nowrap border ${activeTab === 'retakes'
                            ? 'bg-slate-900 text-white border-slate-900 dark:bg-white dark:text-slate-900 dark:border-white'
                            : 'bg-transparent text-slate-600 dark:text-slate-300 border-transparent hover:border-[var(--panel-border)] hover:bg-[var(--panel-muted)]'}`}
                    >
                        Назначение пересдач
                    </a>
                </div>
            </div>
        )}

        {(activeTab === 'retakes' && canSchedule) && (
            <RetakeScheduler
                client:load
                backendApiUrl={backendApiUrl}
                groups={apiGroups}
                subjects={apiSubjects}
                teachers={localTeachers}
                currentUser={{
                    id: String(user.id),
                    role: user.role,
                    departmentIds: user.departmentIds
                }}
            />
        )}

        {(activeTab === 'schedule' && hasOwnSchedule) && (
            <TeacherBoard
                client:load
                teacherFullName={teacherFullName}
                retakes={teacherRetakesFormatted}
                baseSchedule={teacherBaseSchedule}
            />
        )}
    </section>

    <script define:vars={{ backendApiUrl, csrfToken }}>
        const logoutBtn = document.querySelector('#logout-btn');

        logoutBtn?.addEventListener('click', async () => {
            await fetch(`${backendApiUrl}/auth/logout`, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'X-CSRF-Token': csrfToken,
                },
            });
            window.location.href = '/';
        });
    </script>
</Layout>
