---
import Layout from '../../layouts/Layout.astro';
import RetakeScheduler from '../../components/RetakeScheduler.vue';
import TeacherBoard from '../../components/TeacherBoard.vue';
import { fetchBackendFromServer } from '../../lib/backend-api';
import { getPublicBackendApiUrl } from '../../lib/backend-auth';
import { cleanSubjectName } from '../../lib/subjectNorm';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect('/login');
}

if (user.mustChangePassword) {
    return Astro.redirect('/profile?forcePasswordChange=1');
}

const isAdmin = user.role === 'ADMIN';
const isEmployee = user.role === 'EMPLOYEE';
const canSchedule = isAdmin || isEmployee;
const hasOwnSchedule = !!user.teacherUuid;
const activeTab = Astro.url.searchParams.get('tab') || (hasOwnSchedule ? 'schedule' : 'retakes');

let apiGroups = [];
let apiSubjects = [];
let localTeachers = [];

if (canSchedule || hasOwnSchedule) {
    try {
        const dictionaries = await fetchBackendFromServer('/schedule-data/dictionaries', {}, Astro.request);
        apiGroups = dictionaries?.groups ?? [];
        apiSubjects = dictionaries?.subjects ?? [];
    } catch (error) {
        console.error('Failed to load dictionaries', error);
    }
}

if (canSchedule) {
    try {
        localTeachers = await fetchBackendFromServer('/teacher-directory/', {}, Astro.request);
    } catch (error) {
        console.error('Failed to load teacher directory', error);
    }
}

let teacherFullName = user.fullName || user.username;
let teacherBaseSchedule = null;
let teacherRetakesFormatted = [];

if (hasOwnSchedule) {
    try {
        const teacherSchedule = user.teacherUuid
            ? await fetchBackendFromServer(`/schedule-data/teacher/${user.teacherUuid}`, {}, Astro.request)
            : null;

        if (teacherSchedule) {
            teacherFullName = teacherSchedule.teacherFullName;
            teacherBaseSchedule = teacherSchedule.schedule ?? null;
        }

        const myRetakes = await fetchBackendFromServer('/retakes/mine', {}, Astro.request);

        teacherRetakesFormatted = myRetakes.map((retake: any) => ({
            ...retake,
            groupName: apiGroups.find((group: any) => group.uuid === retake.groupUuid)?.number || 'Р СңР ВөР С‘Р В·Р РҶР ВөРЎРғРЎвҖҡР Р…Р В°РЎРҸ Р С–РЎРӮРЎС“Р С—Р С—Р В°',
            subjectName: cleanSubjectName(retake.subjectName || apiSubjects.find((subject: any) => subject.uuid === retake.subjectUuid)?.name || 'Р СңР ВөР С‘Р В·Р РҶР ВөРЎРғРЎвҖҡР Р…Р В°РЎРҸ Р Т‘Р С‘РЎРғРЎвҖ Р С‘Р С—Р В»Р С‘Р Р…Р В°'),
        }));
    } catch (error) {
        console.error('Failed to load teacher retakes', error);
    }
}

const roleLabel = isAdmin ? 'Р С’Р Т‘Р СҳР С‘Р Р…Р С‘РЎРғРЎвҖҡРЎРӮР В°РЎвҖҡР С•РЎРӮ' : isEmployee ? 'Р РҺР С•РЎвҖҡРЎРӮРЎС“Р Т‘Р Р…Р С‘Р С”' : 'Р СҹРЎРӮР ВөР С—Р С•Р Т‘Р В°Р РҶР В°РЎвҖҡР ВөР В»РЎРҠ';
const backendApiUrl = getPublicBackendApiUrl();
const csrfToken = Astro.locals.csrfToken ?? '';
---
<Layout title="Р В Р В°Р ВұР С•РЎвҖЎР С‘Р в„– РЎРғРЎвҖҡР С•Р В»">
    <Fragment slot="nav-center">
        <div class="hidden sm:flex items-center gap-2 min-w-0">
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300 truncate">
                {teacherFullName}
            </span>
            <span class="inline-flex px-2 py-0.5 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
                {roleLabel}
            </span>
        </div>
    </Fragment>

    <Fragment slot="nav-actions">
        {isAdmin && (
            <a href="/admin" class="text-xs font-semibold text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/30 border border-amber-300 dark:border-amber-800/50 px-3 py-1.5 rounded-xl hover:bg-amber-200 dark:hover:bg-amber-900/50 transition-all">
                Р С’Р Т‘Р СҳР С‘Р Р…Р С”Р В°
            </a>
        )}
        <a href="/profile" class="text-xs font-medium text-gray-700 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white px-3 py-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-800 transition-all">
            Р СҹРЎРӮР С•РЎвҖһР С‘Р В»РЎРҠ
        </a>
        <button id="logout-btn" class="text-xs font-medium text-gray-700 dark:text-slate-400 hover:text-rose-600 dark:hover:text-rose-400 px-3 py-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-rose-950/30 transition-all">
            Р вҖҷРЎвҖ№Р в„–РЎвҖҡР С‘
        </button>
    </Fragment>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="mb-6">
            <p class="text-[11px] uppercase tracking-[0.22em] text-slate-500 dark:text-slate-500 font-bold">
                Backend API
            </p>
            <h1 class="mt-3 text-3xl sm:text-4xl font-black tracking-[-0.04em] text-slate-950 dark:text-white">
                Р В Р В°Р ВұР С•РЎвҖЎР С‘Р в„– Р С”Р В°Р ВұР С‘Р Р…Р ВөРЎвҖҡ
            </h1>
            <p class="mt-3 text-sm sm:text-base text-slate-500 dark:text-slate-400 max-w-2xl leading-7">
                Р РҺР ВөРЎРғРЎРғР С‘РЎРҸ Р С‘ Р С—Р С•Р В»РЎРҠР В·Р С•Р РҶР В°РЎвҖҡР ВөР В»РЎРҠ Р С•Р С—РЎРӮР ВөР Т‘Р ВөР В»РЎРҸРЎРӢРЎвҖҡРЎРғРЎРҸ РЎвҖЎР ВөРЎРӮР ВөР В· backend FastAPI. Р ВӨРЎРӮР С•Р Р…РЎвҖҡР ВөР Р…Р Т‘ Р С‘РЎРғР С—Р С•Р В»РЎРҠР В·РЎС“Р ВөРЎвҖҡ РЎвҖҡР С•Р В»РЎРҠР С”Р С• UI Р С‘ backend session cookie.
            </p>
        </div>

        {(hasOwnSchedule && canSchedule) && (
            <div class="mb-6 overflow-x-auto hide-scrollbar">
                <div class="inline-flex p-1 bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
                    <a href="?tab=schedule" class={`px-5 py-2.5 text-sm font-semibold rounded-xl transition-all whitespace-nowrap ${activeTab === 'schedule' ? 'bg-gradient-to-r from-blue-600 to-violet-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-slate-800'}`}>
                        Р СҡР С•РЎвҖҳ РЎРӮР В°РЎРғР С—Р С‘РЎРғР В°Р Р…Р С‘Р Вө
                    </a>
                    <a href="?tab=retakes" class={`px-5 py-2.5 text-sm font-semibold rounded-xl transition-all whitespace-nowrap ${activeTab === 'retakes' ? 'bg-gradient-to-r from-blue-600 to-violet-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-slate-800'}`}>
                        Р СңР В°Р В·Р Р…Р В°РЎвҖЎР ВөР Р…Р С‘Р Вө Р С—Р ВөРЎРӮР ВөРЎРғР Т‘Р В°РЎвҖЎ
                    </a>
                </div>
            </div>
        )}

        {(activeTab === 'retakes' && canSchedule) && (
            <RetakeScheduler
                client:load
                backendApiUrl={backendApiUrl}
                groups={apiGroups}
                subjects={apiSubjects}
                teachers={localTeachers}
                currentUser={{
                    id: String(user.id),
                    role: user.role,
                    departmentIds: user.departmentIds
                }}
            />
        )}

        {(activeTab === 'schedule' && hasOwnSchedule) && (
            <TeacherBoard
                client:load
                teacherFullName={teacherFullName}
                retakes={teacherRetakesFormatted}
                baseSchedule={teacherBaseSchedule}
            />
        )}
    </section>

    <script define:vars={{ backendApiUrl, csrfToken }}>
        const logoutBtn = document.querySelector('#logout-btn');

        logoutBtn?.addEventListener('click', async () => {
            await fetch(`${backendApiUrl}/auth/logout`, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'X-CSRF-Token': csrfToken,
                },
            });
            window.location.href = '/';
        });
    </script>
</Layout>
