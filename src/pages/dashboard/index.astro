---
import Layout from '../../layouts/Layout.astro';
import RetakeScheduler from '../../components/RetakeScheduler.vue';
import TeacherBoard from '../../components/TeacherBoard.vue';
import { db } from '../../db';
import { teachersLocal, users, retakes, retakeTeachers } from '../../db/schema';
import { RaspyxAPI } from '../../lib/api-client';
import { eq } from 'drizzle-orm';

export const prerender = false;

if (!Astro.locals.session) {
    return Astro.redirect('/login');
}

const sessionUser = Astro.locals.user;
const [dbUser] = await db.select().from(users).where(eq(users.id, sessionUser.id));

const isAdmin = dbUser.role === 'ADMIN';
const isEmployee = dbUser.role === 'EMPLOYEE';
const isTeacher = dbUser.role === 'TEACHER';

const canSchedule = isAdmin || isEmployee;
const hasOwnSchedule = !!dbUser.teacherUuid;

const urlTab = Astro.url.searchParams.get('tab');
const defaultTab = hasOwnSchedule ? 'schedule' : 'retakes';
const activeTab = urlTab || defaultTab;

let apiGroups = [];
let apiSubjects = [];
let localTeachers = [];

if (canSchedule) {
    try {
        const groupsRes = await RaspyxAPI.getGroups();
        const subjectsRes = await RaspyxAPI.getSubjects();
        if (groupsRes?.result) apiGroups = groupsRes.result;
        if (subjectsRes?.result) apiSubjects = subjectsRes.result;
    } catch (e) {
        console.error("Ошибка загрузки справочников API", e);
    }
    localTeachers = await db.select().from(teachersLocal).orderBy(teachersLocal.fullName);
}

let teacherRetakesFormatted = [];
let teacherBaseSchedule = null;
let teacherFullName = '';

if (hasOwnSchedule) {
    const [tLocal] = await db.select().from(teachersLocal).where(eq(teachersLocal.uuid, dbUser.teacherUuid));
    if (tLocal) {
        teacherFullName = tLocal.fullName;
        try {
            const schedRes = await RaspyxAPI.getTeacherSchedule(teacherFullName);
            if (schedRes?.result) teacherBaseSchedule = schedRes.result;
        } catch (e) {
            console.error("Ошибка загрузки расписания преподавателя", e);
        }
    }

    const myRetakes = await db.select({
        id: retakes.id,
        groupUuid: retakes.groupUuid,
        subjectUuid: retakes.subjectUuid,
        date: retakes.date,
        timeSlots: retakes.timeSlots,
        room: retakes.roomUuid,
        link: retakes.link,
        attemptNumber: retakes.attemptNumber,
        myRole: retakeTeachers.role
    })
        .from(retakes)
        .innerJoin(retakeTeachers, eq(retakes.id, retakeTeachers.retakeId))
        .where(eq(retakeTeachers.teacherUuid, dbUser.teacherUuid));

    try {
        const groupsRes = await RaspyxAPI.getGroups();
        const subjectsRes = await RaspyxAPI.getSubjects();
        const groups = groupsRes?.result || [];
        const subjects = subjectsRes?.result || [];

        teacherRetakesFormatted = myRetakes.map(r => ({
            ...r,
            groupName: groups.find((g: any) => g.uuid === r.groupUuid)?.number || 'Неизвестная группа',
            subjectName: subjects.find((s: any) => s.uuid === r.subjectUuid)?.name || 'Неизвестный предмет',
        }));
    } catch (e) {}
}

let roleBadge = 'Преподаватель';
let roleColorClass = 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300';

if (isAdmin) {
    roleBadge = 'Администратор';
    roleColorClass = 'bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-400';
} else if (isEmployee) {
    roleBadge = 'Диспетчер';
    roleColorClass = 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400';
}
---

<Layout title="Рабочий стол — Пересдачи МПУ">

    <!-- Центральная часть navbar: имя пользователя + роль -->
    <Fragment slot="nav-center">
        <div class="flex items-center gap-2 ml-3 min-w-0">
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300 truncate hidden sm:block">
                {teacherFullName || dbUser?.username}
            </span>
            <span class={`hidden sm:inline-flex px-2 py-0.5 rounded-md text-xs font-semibold ${roleColorClass}`}>
                {roleBadge}
            </span>
        </div>
    </Fragment>

    <!-- Правая часть navbar: кнопки действий -->
    <Fragment slot="nav-actions">
        {isAdmin && (
            <a href="/admin"
                class="text-xs font-medium text-amber-700 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-800/50 px-3 py-1.5 rounded-lg hover:bg-amber-100 dark:hover:bg-amber-900/50 transition-colors">
                Админка
            </a>
        )}
        <a href="/profile"
            class="text-xs font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors border border-transparent hover:border-slate-200 dark:hover:border-slate-700">
            Профиль
        </a>
        <button id="logout-btn"
            class="text-xs font-medium text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 px-3 py-1.5 rounded-lg hover:bg-red-50 dark:hover:bg-red-950/30 transition-colors border border-transparent hover:border-red-200 dark:hover:border-red-900/50">
            Выйти
        </button>
    </Fragment>

    <div class="min-h-[calc(100vh-3.5rem)] bg-slate-50 dark:bg-slate-950 transition-colors">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

            <!-- Tabs (если есть расписание И права назначать) -->
            {(hasOwnSchedule && canSchedule) && (
                <div class="mb-6 overflow-x-auto hide-scrollbar">
                    <div class="flex p-1 bg-white dark:bg-slate-900 rounded-xl w-max border border-slate-200 dark:border-slate-800 shadow-sm">
                        <a href="?tab=schedule"
                            class={`px-4 py-2 text-sm font-medium rounded-lg transition-all whitespace-nowrap ${
                                activeTab === 'schedule'
                                    ? 'bg-indigo-600 text-white shadow-sm'
                                    : 'text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800'
                            }`}>
                            Моё расписание
                        </a>
                        <a href="?tab=retakes"
                            class={`px-4 py-2 text-sm font-medium rounded-lg transition-all whitespace-nowrap ${
                                activeTab === 'retakes'
                                    ? 'bg-indigo-600 text-white shadow-sm'
                                    : 'text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800'
                            }`}>
                            Назначение пересдач
                        </a>
                    </div>
                </div>
            )}

            {(activeTab === 'retakes' && canSchedule) && (
                <RetakeScheduler
                    client:load
                    groups={apiGroups}
                    subjects={apiSubjects}
                    teachers={localTeachers}
                    currentUser={{
                        id: dbUser.id,
                        role: dbUser.role,
                        departmentIds: dbUser.departmentIds
                    }}
                />
            )}

            {(activeTab === 'schedule' && hasOwnSchedule) && (
                <TeacherBoard
                    client:load
                    teacherFullName={teacherFullName}
                    retakes={teacherRetakesFormatted}
                    baseSchedule={teacherBaseSchedule}
                />
            )}

        </div>
    </div>

    <script>
        import { actions } from 'astro:actions';
        const logoutBtn = document.querySelector('#logout-btn');
        logoutBtn?.addEventListener('click', async () => {
            await actions.auth.logout();
            window.location.href = '/';
        });
    </script>
</Layout>
