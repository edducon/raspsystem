---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

if (Astro.locals.session) {
    return Astro.redirect('/dashboard');
}
---

<Layout title="Вход">
    <a
            slot="nav-actions"
            href="/"
            class="inline-flex items-center justify-center h-10 px-4 rounded-2xl border border-gray-300 dark:border-white/10 bg-white dark:bg-white/5 text-gray-700 dark:text-white/80 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-white/10 hover:border-gray-400 dark:hover:border-white/15 backdrop-blur-xl text-sm font-semibold transition-all duration-300 hover:-translate-y-0.5"
    >
        &larr; Расписание
    </a>

    <div class="relative min-h-[calc(100vh-4rem)] overflow-hidden">
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_16%_18%,rgba(239,68,68,0.24),transparent_20%),radial-gradient(circle_at_84%_16%,rgba(59,130,246,0.16),transparent_18%),linear-gradient(180deg,rgba(8,10,14,0.22),transparent_65%)] dark:bg-[radial-gradient(circle_at_16%_18%,rgba(239,68,68,0.28),transparent_20%),radial-gradient(circle_at_84%_16%,rgba(59,130,246,0.18),transparent_18%),linear-gradient(180deg,rgba(255,255,255,0.03),transparent_65%)]"></div>
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#333333_1px,transparent_1px),linear-gradient(to_bottom,#333333_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,white_1px,transparent_1px),linear-gradient(to_bottom,white_1px,transparent_1px)] bg-[size:40px_40px] opacity-[0.12] dark:opacity-[0.05]"></div>
            <div class="absolute top-[-8%] left-[10%] w-[420px] h-[420px] bg-red-500/10 rounded-full blur-3xl"></div>
            <div class="absolute bottom-[-10%] right-[8%] w-[360px] h-[360px] bg-blue-500/10 rounded-full blur-3xl"></div>
        </div>

        <div class="relative z-10 min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12">
            <div class="w-full max-w-5xl grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-8 items-center">
                <!-- Left side -->
                <div class="hidden lg:block">
                    <div class="max-w-xl">
                        <h1 class="text-5xl xl:text-6xl font-black tracking-[-0.05em] leading-[0.95] text-slate-950 dark:text-white">
                            Вход
                            <span class="block text-slate-600 dark:text-white/70">
                                в систему
                            </span>
                        </h1>

                        <p class="mt-6 text-base xl:text-lg leading-8 text-slate-600 dark:text-white/65 max-w-lg">
                            Доступ к панели управления расписанием пересдач,
                            сотрудникам, кафедрам и служебным инструментам системы.
                        </p>


                    </div>
                </div>

                <div class="w-full max-w-[420px] mx-auto lg:mx-0 lg:ml-auto">
                    <div class="rounded-[30px] border border-white/10 bg-white/75 dark:bg-white/[0.04] backdrop-blur-2xl shadow-[0_24px_80px_rgba(15,23,42,0.18)] p-6 sm:p-7 lg:p-8">
                        <div class="text-center mb-7">
                            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center mx-auto mb-5 shadow-lg overflow-hidden">
                                <img
                                        src="/image/logo.png"
                                        alt="Логотип университета"
                                        class="w-10 h-10 object-contain"
                                />
                            </div>

                            <h2 class="text-2xl sm:text-3xl font-black tracking-[-0.04em] text-slate-950 dark:text-white">
                                Вход в систему
                            </h2>

                            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
                                Управление расписанием пересдач
                            </p>
                        </div>

                        <form id="login-form" class="space-y-5">
                            <div
                                    id="error-message"
                                    class="hidden rounded-2xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3.5 text-sm text-red-600 dark:text-red-400 font-medium"
                            ></div>

                            <div>
                                <label
                                        for="username"
                                        class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 mb-2 uppercase tracking-[0.18em]"
                                >
                                    Логин
                                </label>

                                <input
                                        id="username"
                                        name="username"
                                        type="text"
                                        required
                                        autocomplete="username"
                                        class="w-full h-12 px-4 rounded-2xl border border-slate-300 dark:border-white/10 text-sm text-slate-900 dark:text-white bg-white dark:bg-white/[0.03] focus:outline-none focus:ring-4 focus:ring-red-500/10 focus:border-red-400 dark:focus:border-red-500 transition-all placeholder:text-slate-400"
                                />
                            </div>

                            <div>
                                <label
                                        for="password"
                                        class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 mb-2 uppercase tracking-[0.18em]"
                                >
                                    Пароль
                                </label>

                                <input
                                        id="password"
                                        name="password"
                                        type="password"
                                        required
                                        autocomplete="current-password"
                                        class="w-full h-12 px-4 rounded-2xl border border-slate-300 dark:border-white/10 text-sm text-slate-900 dark:text-white bg-white dark:bg-white/[0.03] focus:outline-none focus:ring-4 focus:ring-red-500/10 focus:border-red-400 dark:focus:border-red-500 transition-all placeholder:text-slate-400"
                                />
                            </div>

                            <button
                                    type="submit"
                                    id="submit-btn"
                                    class="w-full h-12 px-4 bg-red-500 hover:bg-blue-600 text-white text-sm font-black rounded-2xl shadow-[0_16px_40px_rgba(239,68,68,0.22)] hover:shadow-[0_20px_46px_rgba(37,99,235,0.28)] focus:outline-none focus:ring-4 focus:ring-red-500/20 hover:focus:ring-blue-500/20 transition-all duration-300 disabled:opacity-60 disabled:cursor-not-allowed hover:-translate-y-0.5"
                            >
                                Войти
                            </button>
                        </form>

                        <div class="mt-6 pt-5 border-t border-slate-100 dark:border-white/10">
                            <p class="text-xs text-center text-slate-400 dark:text-slate-500 leading-6">
                                Доступ предоставляется только сотрудникам системы
                                с созданным профилем.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { actions } from 'astro:actions';

        const form = document.querySelector('#login-form') as HTMLFormElement;
        const errorDiv = document.querySelector('#error-message') as HTMLDivElement;
        const submitBtn = document.querySelector('#submit-btn') as HTMLButtonElement;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorDiv.classList.add('hidden');
            submitBtn.textContent = 'Проверка...';
            submitBtn.disabled = true;

            const formData = new FormData(form);
            const { error } = await actions.auth.login(formData);

            if (error) {
                errorDiv.textContent = error.message;
                errorDiv.classList.remove('hidden');
                submitBtn.textContent = 'Войти';
                submitBtn.disabled = false;
            } else {
                window.location.href = '/dashboard';
            }
        });
    </script>
</Layout>