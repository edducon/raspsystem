---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { db } from '../db';
import { users, teachersLocal, departments } from '../db/schema';
import { eq, inArray } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect('/login');
}

const [profileData] = await db.select({
    username: users.username,
    role: users.role,
    fullName: teachersLocal.fullName,
    departmentIds: teachersLocal.departmentIds
})
    .from(users)
    .leftJoin(teachersLocal, eq(users.teacherUuid, teachersLocal.uuid))
    .where(eq(users.id, user.id));

let userDepartmentsNames: string[] = [];
if (profileData?.departmentIds && profileData.departmentIds.length > 0) {
    const depts = await db.select({ name: departments.name })
        .from(departments)
        .where(inArray(departments.id, profileData.departmentIds));
    userDepartmentsNames = depts.map(d => d.name);
}

const displayName = profileData?.fullName || (profileData?.role === 'ADMIN' ? 'Главный Администратор' : 'Сотрудник');
const initial = displayName.charAt(0).toUpperCase();

let roleLabel = 'Преподаватель';
let roleClass = 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400';
if (profileData?.role === 'ADMIN') {
    roleLabel = 'Администратор';
    roleClass = 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400';
} else if (profileData?.role === 'EMPLOYEE') {
    roleLabel = 'Диспетчер';
    roleClass = 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400';
}
---

<Layout title="Профиль — Пересдачи МПУ">
    <Fragment slot="nav-actions">
        <a href="/dashboard"
            class="text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white px-3 py-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">
            &larr; Дашборд
        </a>
    </Fragment>

    <div class="min-h-[calc(100vh-4rem)]">
        <div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">

            <!-- Profile card -->
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <!-- Header with gradient -->
                <div class="relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 via-violet-600/5 to-transparent dark:from-blue-600/10 dark:via-violet-600/10"></div>
                    <div class="relative px-6 py-8 flex flex-col sm:flex-row items-center sm:items-start gap-5">
                        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-600 to-violet-600 flex items-center justify-center text-white text-2xl font-bold shadow-xl shadow-blue-600/20 shrink-0">
                            {initial}
                        </div>
                        <div class="text-center sm:text-left">
                            <h1 class="text-xl font-bold text-slate-900 dark:text-white">{displayName}</h1>
                            <div class="flex flex-wrap justify-center sm:justify-start items-center gap-2 mt-2">
                                <span class={`px-2.5 py-0.5 rounded-lg text-xs font-bold ${roleClass}`}>{roleLabel}</span>
                                <span class="font-mono text-xs text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2.5 py-0.5 rounded-lg">
                                    {profileData?.username}
                                </span>
                            </div>
                            {userDepartmentsNames.length > 0 && (
                                <div class="flex flex-wrap justify-center sm:justify-start gap-1.5 mt-3">
                                    {userDepartmentsNames.map(dept => (
                                        <span class="text-xs bg-blue-50 dark:bg-blue-950/40 text-blue-600 dark:text-blue-400 border border-blue-100 dark:border-blue-800/50 px-2.5 py-1 rounded-full font-medium">
                                            {dept}
                                        </span>
                                    ))}
                                </div>
                            )}
                        </div>
                    </div>
                </div>

                <!-- Change password -->
                <div class="px-6 py-7 border-t border-slate-100 dark:border-slate-800/60">
                    <h2 class="text-base font-bold text-slate-900 dark:text-white mb-5">Смена пароля</h2>

                    <form id="password-form" class="max-w-sm space-y-4">
                        <div id="status-message" class="hidden rounded-xl p-3.5 text-sm font-medium"></div>

                        <div>
                            <label for="currentPassword" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Текущий пароль</label>
                            <input type="password" name="currentPassword" id="currentPassword" required
                                class="w-full px-4 py-2.5 border border-slate-300 dark:border-slate-700 rounded-xl text-sm bg-white dark:bg-slate-950 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                        </div>

                        <div>
                            <label for="newPassword" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Новый пароль</label>
                            <input type="password" name="newPassword" id="newPassword" required minlength="6"
                                class="w-full px-4 py-2.5 border border-slate-300 dark:border-slate-700 rounded-xl text-sm bg-white dark:bg-slate-950 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                            <p class="text-xs text-slate-400 mt-1.5">Минимум 6 символов</p>
                        </div>

                        <div class="pt-2">
                            <button type="submit" id="submit-btn"
                                class="bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white text-sm font-bold py-2.5 px-6 rounded-xl shadow-lg shadow-blue-600/20 transition-all disabled:opacity-60 disabled:cursor-not-allowed flex items-center gap-2">
                                <span>Сохранить</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>

    <script>
        import { actions } from 'astro:actions';

        const form = document.querySelector('#password-form') as HTMLFormElement;
        const statusDiv = document.querySelector('#status-message') as HTMLDivElement;
        const submitBtn = document.querySelector('#submit-btn') as HTMLButtonElement;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();

            submitBtn.disabled = true;
            submitBtn.querySelector('span')!.textContent = 'Сохранение...';
            statusDiv.className = 'hidden rounded-xl p-3.5 text-sm font-medium';

            const formData = new FormData(form);
            const { data, error } = await actions.auth.changePassword(formData);

            submitBtn.disabled = false;
            submitBtn.querySelector('span')!.textContent = 'Сохранить';

            if (error) {
                statusDiv.className = 'rounded-xl p-3.5 text-sm font-medium bg-rose-50 dark:bg-rose-950/50 text-rose-600 dark:text-rose-400 border border-rose-200 dark:border-rose-800/60';
                statusDiv.textContent = error.message;
            } else {
                statusDiv.className = 'rounded-xl p-3.5 text-sm font-medium bg-emerald-50 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800/60';
                statusDiv.textContent = data.message;
                form.reset();
            }
        });
    </script>
</Layout>
