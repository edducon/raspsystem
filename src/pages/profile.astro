---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { fetchBackendFromServer } from '../lib/backend-api';
import { getPublicBackendApiUrl } from '../lib/backend-auth';

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect('/login');
}
const forcePasswordChange = Astro.url.searchParams.get('forcePasswordChange') === '1' || user.mustChangePassword;

let teacherProfile = null;
if (user.teacherUuid) {
    try {
        teacherProfile = await fetchBackendFromServer(`/teacher-directory/${user.teacherUuid}`, {}, Astro.request);
    } catch (error) {
        console.error('Failed to load teacher profile', error);
    }
}

let departmentNames: string[] = [];
if (user.departmentIds.length > 0) {
    try {
        const departments = await fetchBackendFromServer('/departments/', {}, Astro.request);
        departmentNames = departments
            .filter((department: any) => user.departmentIds.includes(department.id))
            .map((department: any) => department.name);
    } catch (error) {
        console.error('Failed to load departments', error);
    }
}

const displayName = teacherProfile?.fullName || user.fullName || user.username;
const roleLabel = user.role === 'ADMIN' ? 'Администратор' : user.role === 'EMPLOYEE' ? 'Сотрудник' : 'Преподаватель';
const backendApiUrl = getPublicBackendApiUrl();
const csrfToken = Astro.locals.csrfToken ?? '';
---
<Layout title="Профиль">
    <Fragment slot="nav-actions">
        <a
            href="/dashboard"
            class="inline-flex items-center justify-center h-10 px-4 rounded-2xl border border-slate-300/80 dark:border-white/10 bg-[var(--panel-bg-strong)] dark:bg-[var(--panel-muted)] text-slate-800 dark:text-white text-sm font-semibold hover:border-slate-400 dark:hover:border-white/20 transition"
        >
            &larr; Дашборд
        </a>
    </Fragment>

    <section class="max-w-4xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
        <div class="rounded-[32px] border border-[var(--panel-border)] bg-[var(--panel-bg)] shadow-[var(--panel-shadow-strong)] overflow-hidden">
            <div class="px-6 py-8 sm:px-8 sm:py-9 border-b border-[var(--panel-border)]">
                <p class="academic-kicker">Профиль пользователя</p>
                <h1 class="mt-3 text-3xl sm:text-4xl academic-title text-slate-950 dark:text-white">
                    {displayName}
                </h1>
                <div class="mt-4 flex flex-wrap items-center gap-2">
                    <span class="px-3 py-1 rounded-xl text-xs font-bold bg-[var(--panel-muted)] text-slate-700 dark:text-slate-300 border border-[var(--panel-border)]">
                        {roleLabel}
                    </span>
                    <span class="tnum font-mono text-xs text-slate-500 dark:text-slate-400 bg-[var(--panel-muted)] border border-[var(--panel-border)] px-3 py-1 rounded-xl">
                        {user.username}
                    </span>
                </div>

                {departmentNames.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                        {departmentNames.map((department) => (
                            <span class="text-xs bg-[var(--accent-soft)] text-[var(--accent-strong)] border border-[var(--panel-border)] px-3 py-1 rounded-full font-semibold">
                                {department}
                            </span>
                        ))}
                    </div>
                )}
            </div>

            <div class="px-6 py-7 sm:px-8 sm:py-8">
                <div class="mb-6">
                    {forcePasswordChange && (
                        <div class="mb-4 rounded-2xl border border-amber-200 dark:border-amber-500/20 bg-amber-50 dark:bg-amber-500/10 px-4 py-3 text-sm font-medium text-amber-800 dark:text-amber-300">
                            Для продолжения работы нужно сменить стартовый пароль.
                        </div>
                    )}
                    <p class="academic-kicker">Безопасность</p>
                    <h2 class="mt-2 text-xl sm:text-2xl academic-title text-slate-950 dark:text-white">
                        Смена пароля
                    </h2>
                    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400 max-w-lg leading-7">
                        Пароль обновляется через backend endpoint и сразу применяется к текущей учётной записи.
                    </p>
                </div>

                <form id="password-form" class="max-w-md space-y-5">
                    <div id="status-message" class="hidden rounded-2xl px-4 py-3.5 text-sm font-medium"></div>

                    <div>
                        <label for="currentPassword" class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 mb-2 uppercase tracking-[0.18em]">
                            Текущий пароль
                        </label>
                        <input id="currentPassword" name="currentPassword" type="password" required class="w-full h-12 px-4 border border-slate-300 dark:border-white/10 rounded-2xl text-sm bg-[var(--panel-bg-strong)] dark:bg-[var(--panel-muted)] dark:text-white focus:outline-none focus:ring-4 focus:ring-sky-500/10 focus:border-sky-600 dark:focus:border-sky-400 transition-all" />
                    </div>

                    <div>
                        <label for="newPassword" class="block text-[11px] font-bold text-slate-500 dark:text-slate-400 mb-2 uppercase tracking-[0.18em]">
                            Новый пароль
                        </label>
                        <input id="newPassword" name="newPassword" type="password" required minlength="6" class="w-full h-12 px-4 border border-slate-300 dark:border-white/10 rounded-2xl text-sm bg-[var(--panel-bg-strong)] dark:bg-[var(--panel-muted)] dark:text-white focus:outline-none focus:ring-4 focus:ring-sky-500/10 focus:border-sky-600 dark:focus:border-sky-400 transition-all" />
                    </div>

                    <button id="submit-btn" type="submit" class="h-12 px-6 bg-slate-900 hover:bg-slate-800 dark:bg-white dark:hover:bg-slate-200 text-white dark:text-slate-900 text-sm font-black rounded-2xl shadow-[var(--panel-shadow)] transition-all disabled:opacity-60 disabled:cursor-not-allowed">
                        <span>Сохранить</span>
                    </button>
                </form>
            </div>
        </div>
    </section>

    <script define:vars={{ backendApiUrl, csrfToken }}>
        const form = document.querySelector('#password-form');
        const statusDiv = document.querySelector('#status-message');
        const submitBtn = document.querySelector('#submit-btn');

        form?.addEventListener('submit', async (event) => {
            event.preventDefault();

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.querySelector('span').textContent = 'Сохранение...';
            }
            if (statusDiv) {
                statusDiv.className = 'hidden rounded-2xl px-4 py-3.5 text-sm font-medium';
            }

            const formData = new FormData(form);
            const response = await fetch(`${backendApiUrl}/auth/change-password`, {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-CSRF-Token': csrfToken,
                },
                body: JSON.stringify({
                    current_password: formData.get('currentPassword'),
                    new_password: formData.get('newPassword'),
                }),
            });

            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.querySelector('span').textContent = 'Сохранить';
            }

            if (!response.ok) {
                const payload = await response.json().catch(() => ({}));
                if (statusDiv) {
                    statusDiv.className = 'rounded-2xl px-4 py-3.5 text-sm font-medium bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-300 border border-red-200 dark:border-red-500/20';
                    statusDiv.textContent = payload.detail ?? 'Не удалось обновить пароль';
                }
                return;
            }

            const payload = await response.json();
            if (statusDiv) {
                statusDiv.className = 'rounded-2xl px-4 py-3.5 text-sm font-medium bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 border border-emerald-200 dark:border-emerald-500/20';
                statusDiv.textContent = payload.message;
            }
            form.reset();
            if (window.location.search.includes('forcePasswordChange=1')) {
                window.setTimeout(() => {
                    window.location.href = '/dashboard';
                }, 900);
            }
        });
    </script>
</Layout>
