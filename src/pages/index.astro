---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import StudentBoard from '../components/StudentBoard.vue';
import { db } from '../db';
import { retakes, retakeTeachers, teachersLocal } from '../db/schema';
import { RaspyxAPI } from '../lib/api-client';
import { eq, inArray } from 'drizzle-orm';

let apiGroups = [];
let apiSubjects = [];
let allRetakes = [];
try {
    const [[gRes, sRes], dbRetakes] = await Promise.all([
        Promise.all([ RaspyxAPI.getGroups(), RaspyxAPI.getSubjects() ]),
        db.select().from(retakes)
    ]);
    if (gRes?.result) apiGroups = gRes.result;
    if (sRes?.result) apiSubjects = sRes.result;
    allRetakes = dbRetakes;
} catch (e) {}

const today = new Date().toISOString().split('T')[0];
const retakeIds = allRetakes.map(r => r.id);
let teachersMap: Record<number, {name: string, role: string}[]> = {};

if (retakeIds.length > 0) {
    const relations = await db
        .select({
            retakeId: retakeTeachers.retakeId,
            fullName: teachersLocal.fullName,
            role: retakeTeachers.role
        })
        .from(retakeTeachers)
        .leftJoin(teachersLocal, eq(retakeTeachers.teacherUuid, teachersLocal.uuid))
        .where(inArray(retakeTeachers.retakeId, retakeIds));

    relations.forEach(rel => {
        if (!teachersMap[rel.retakeId]) teachersMap[rel.retakeId] = [];
        if (rel.fullName && rel.role) {
            teachersMap[rel.retakeId].push({ name: rel.fullName, role: rel.role });
        }
    });
}

const formattedRetakes = allRetakes.map(r => ({
    id: r.id,
    groupUuid: r.groupUuid,
    groupName: apiGroups.find((g: any) => g.uuid === r.groupUuid)?.number || 'Неизвестная группа',
    subjectName: apiSubjects.find((s: any) => s.uuid === r.subjectUuid)?.name || 'Неизвестный предмет',
    date: r.date,
    timeSlots: r.timeSlots,
    room: r.roomUuid,
    link: r.link,
    attemptNumber: r.attemptNumber,
    teachers: teachersMap[r.id] || []
}));
---

<Layout title="Расписание ликвидации задолженностей">
    <header class="sticky top-0 z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 shadow-sm transition-colors">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-7 h-7 bg-slate-900 dark:bg-white text-white dark:text-slate-900 flex items-center justify-center font-bold text-base rounded-md">П</div>
                <div class="font-semibold text-slate-900 dark:text-white text-sm">Расписание пересдач</div>
            </div>
            <a href="/login" class="text-xs text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white font-medium transition-colors border border-slate-200 dark:border-slate-700 px-3 py-1.5 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800">
                Вход для сотрудников
            </a>
        </div>
    </header>

    <section class="bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800/60 transition-colors">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-1">Факультет информационных технологий</p>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Расписание пересдач</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1.5">Московский Политехнический Университет</p>
        </div>
    </section>

    <main class="min-h-screen py-8 px-4 sm:px-6 lg:px-8 bg-slate-50/50 dark:bg-slate-950 flex flex-col transition-colors">
        <div class="flex-grow">
            <StudentBoard client:load groups={apiGroups} retakes={formattedRetakes} today={today} />
        </div>
    </main>
</Layout>