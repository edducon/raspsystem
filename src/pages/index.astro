---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import StudentBoard from '../components/StudentBoard.vue';
import { fetchBackendFromServer } from '../lib/backend-api';
import { cleanSubjectName } from '../lib/subjectNorm';

let apiGroups: any[] = [];
let apiSubjects: any[] = [];
let allRetakes: any[] = [];

try {
    const [dictionaries, retakesRes] = await Promise.all([
        fetchBackendFromServer('/schedule-data/dictionaries'),
        fetchBackendFromServer('/retakes/'),
    ]) as [any, any[]];

    apiGroups = dictionaries?.groups ?? [];
    apiSubjects = dictionaries?.subjects ?? [];
    allRetakes = retakesRes ?? [];
} catch (error) {
    console.error('Failed to load public retakes', error);
}

const today = new Date().toISOString().split('T')[0];

const formattedRetakes = allRetakes.map((retake: any) => ({
    id: retake.id,
    groupUuid: retake.groupUuid,
    groupName:
        apiGroups.find((group: any) => group.uuid === retake.groupUuid)?.number || 'Неизвестная группа',
    subjectName: cleanSubjectName(
        retake.subjectName ||
        apiSubjects.find((subject: any) => subject.uuid === retake.subjectUuid)?.name ||
        'Неизвестная дисциплина'
    ),
    date: retake.date,
    timeSlots: retake.timeSlots,
    room: retake.roomUuid,
    link: retake.link,
    attemptNumber: retake.attemptNumber,
    teachers: retake.teachers || [],
}));
---

<Layout title="Расписание пересдач">
    <a
            slot="nav-actions"
            href="/login"
            data-arc-trigger
            class="inline-flex items-center justify-center h-10 px-4 rounded-xl border border-slate-300 bg-white text-slate-900 hover:bg-slate-100 text-sm font-semibold transition"
    >
        Войти
    </a>

    <div class="hero-shell min-h-screen bg-[#f5f5f8] dark:bg-[#05070b]">
        <div class="hero-arcs" aria-hidden="true">
            <svg class="hero-arcs-svg" viewBox="0 0 1600 1100" preserveAspectRatio="none">
                <defs>
                    <linearGradient id="arcWhite" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#f8fafc" />
                        <stop offset="72%" stop-color="#dce2f8" />
                        <stop offset="100%" stop-color="#becaf2" />
                    </linearGradient>

                    <linearGradient id="arcBlue" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#a5b8ff" />
                        <stop offset="100%" stop-color="#6f8ff0" />
                    </linearGradient>

                    <linearGradient id="arcCyan" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#4ef5ff" />
                        <stop offset="100%" stop-color="#2cd3ff" />
                    </linearGradient>
                </defs>
                <path
                        class="arc-base arc-base-left"
                        d="M -120 38
                       C 260 52, 590 205, 820 470
                       C 960 632, 1045 840, 1125 1110"
                />
                <path
                        class="arc-base arc-base-right"
                        d="M 1122 1110
                       C 1148 965, 1198 835, 1288 724
                       C 1368 626, 1478 560, 1638 520"
                />
                <path
                        class="arc-trace arc-trace-left"
                        d="M -120 38
                       C 260 52, 590 205, 820 470
                       C 960 632, 1045 840, 1125 1110"
                />
                <path
                        class="arc-trace arc-trace-right"
                        d="M 1122 1110
                       C 1148 965, 1198 835, 1288 724
                       C 1368 626, 1478 560, 1638 520"
                />

                <!-- свечение -->
                <path
                        class="arc-glow arc-glow-left"
                        d="M -120 38
                       C 260 52, 590 205, 820 470
                       C 960 632, 1045 840, 1125 1110"
                />
                <path
                        class="arc-glow arc-glow-right"
                        d="M 1122 1110
                       C 1148 965, 1198 835, 1288 724
                       C 1368 626, 1478 560, 1638 520"
                />
            </svg>
        </div>

        <section class="relative z-10 pt-10 pb-8 sm:pt-14 sm:pb-10">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="max-w-4xl">
                    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-[-0.05em] text-slate-950 dark:text-white">
                        Расписание пересдач
                    </h1>

                    <p class="mt-4 text-lg sm:text-xl text-slate-500 dark:text-slate-400 max-w-3xl">
                        Найдите пересдачу по группе, предмету или преподавателю
                    </p>

                    <div class="mt-8">
                        <a
                                href="#board"
                                data-arc-trigger
                                class="inline-flex items-center justify-center h-12 px-6 rounded-2xl bg-red-500 text-white text-sm font-bold shadow-[0_12px_30px_rgba(239,68,68,0.22)] hover:bg-red-600 transition-all duration-200"
                        >
                            Перейти к поиску
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section id="board" class="relative z-10 pb-16 sm:pb-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="rounded-[32px] border border-slate-200/80 bg-white/90 backdrop-blur-sm shadow-[0_24px_80px_rgba(15,23,42,0.08)] p-4 sm:p-6 lg:p-8 dark:border-white/10 dark:bg-white/[0.03]">
                    <StudentBoard
                            client:load
                            groups={apiGroups}
                            retakes={formattedRetakes}
                            today={today}
                    />
                </div>
            </div>
        </section>
    </div>

    <style is:global>
        .hero-shell {
            position: relative;
            overflow: hidden;
        }

        .hero-arcs {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }

        .hero-arcs-svg {
            width: 100%;
            height: 100%;
            display: block;
        }

        .arc-base,
        .arc-trace,
        .arc-glow {
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
            vector-effect: non-scaling-stroke;
        }


        .arc-base-left {
            stroke: url(#arcWhite);
            stroke-width: 56;
            opacity: 0.94;
        }

        .arc-base-right {
            stroke: url(#arcBlue);
            stroke-width: 56;
            opacity: 0.94;
        }


        .arc-glow-left {
            stroke: rgba(255,255,255,0.12);
            stroke-width: 92;
            filter: blur(24px);
            opacity: 0.42;
        }

        .arc-glow-right {
            stroke: rgba(111,143,240,0.16);
            stroke-width: 92;
            filter: blur(24px);
            opacity: 0.42;
        }

        .arc-trace {
            opacity: 0;
            stroke-dasharray: 3200;
            stroke-dashoffset: 3200;
        }
        .arc-trace-left {
            stroke: #ffffff;
            stroke-width: 64;
            filter: drop-shadow(0 0 18px rgba(255,255,255,0.24));
        }
        .arc-trace-right {
            stroke: #98b2ff;
            stroke-width: 64;
            filter: drop-shadow(0 0 20px rgba(152,178,255,0.28));
        }
        .arc-trace-cyan {
            stroke: #41f2ff;
            stroke-width: 8;
            filter: drop-shadow(0 0 10px rgba(65,242,255,0.45));
            stroke-dasharray: 120;
            stroke-dashoffset: 120;
        }
        .hero-shell.is-arc-animating .arc-trace-left {
            animation: arcDrawLeft 1.2s cubic-bezier(.2,.7,.2,1) forwards;
        }
        .hero-shell.is-arc-animating .arc-trace-right {
            animation: arcDrawRight 1.35s cubic-bezier(.22,.7,.2,1) 0.82s forwards;
        }
        .hero-shell.is-arc-animating .arc-base-left {
            animation: arcBasePulseLeft 1.5s ease;
        }
        .hero-shell.is-arc-animating .arc-base-right {
            animation: arcBasePulseRight 1.5s ease 0.72s;
        }
        .hero-shell.is-arc-animating .arc-glow-left {
            animation: arcGlowPulse 1.35s ease;
        }

        .hero-shell.is-arc-animating .arc-glow-right {
            animation: arcGlowPulse 1.35s ease 0.72s;
        }
        @keyframes arcDrawLeft {
            0% {
                stroke-dashoffset: 2600;
                opacity: 0;
            }
            8% {
                opacity: 1;
            }
            76% {
                stroke-dashoffset: 0;
                opacity: 1;
            }
            100% {
                stroke-dashoffset: 0;
                opacity: 0;
            }
        }

        @keyframes arcDrawRight {
            0% {
                stroke-dashoffset: 3200;
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            85% {
                stroke-dashoffset: 0;
                opacity: 1;
            }
            100% {
                stroke-dashoffset: 0;
                opacity: 0;
            }
        }

        @keyframes arcDrawCyan {
            0% {
                stroke-dashoffset: 120;
                opacity: 0;
            }
            20% {
                opacity: 1;
            }
            80% {
                stroke-dashoffset: 0;
                opacity: 1;
            }
            100% {
                stroke-dashoffset: 0;
                opacity: 0;
            }
        }

        @keyframes arcBasePulseLeft {
            0%, 100% {
                opacity: 0.94;
                filter: none;
            }
            50% {
                opacity: 1;
                filter: drop-shadow(0 0 24px rgba(255,255,255,0.14));
            }
        }

        @keyframes arcBasePulseRight {
            0%, 100% {
                opacity: 0.94;
                filter: none;
            }
            50% {
                opacity: 1;
                filter: drop-shadow(0 0 24px rgba(152,178,255,0.18));
            }
        }

        @keyframes arcGlowPulse {
            0%, 100% {
                opacity: 0.42;
            }
            50% {
                opacity: 0.74;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .hero-shell.is-arc-animating .arc-trace-left,
            .hero-shell.is-arc-animating .arc-trace-right,
            .hero-shell.is-arc-animating .arc-trace-cyan,
            .hero-shell.is-arc-animating .arc-base-left,
            .hero-shell.is-arc-animating .arc-base-right,
            .hero-shell.is-arc-animating .arc-glow-left,
            .hero-shell.is-arc-animating .arc-glow-right {
                animation: none !important;
            }
        }
    </style>

    <script>
        (() => {
            const hero = document.querySelector('.hero-shell');
            const triggers = document.querySelectorAll('[data-arc-trigger]');
            if (!hero || !triggers.length) return;

            let timer;

            const runAnimation = () => {
                hero.classList.remove('is-arc-animating');
                void hero.offsetWidth;
                hero.classList.add('is-arc-animating');

                clearTimeout(timer);
                timer = setTimeout(() => {
                    hero.classList.remove('is-arc-animating');
                }, 2100);
            };

            triggers.forEach((el) => {
                el.addEventListener('mouseenter', runAnimation);
                el.addEventListener('focus', runAnimation);
            });
        })();
    </script>
</Layout>