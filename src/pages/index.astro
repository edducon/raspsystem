---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import MainScheduleBoard from '../components/MainScheduleBoard.vue';
import StudentBoard from '../components/StudentBoard.vue';
import { fetchBackendFromServer } from '../lib/backend-api';
import { cleanSubjectName } from '../lib/subjectNorm';

let apiGroups: any[] = [];
let apiSubjects: any[] = [];
let allRetakes: any[] = [];

try {
    const [dictionaries, retakesRes] = await Promise.all([
        fetchBackendFromServer('/schedule-data/dictionaries'),
        fetchBackendFromServer('/retakes/'),
    ]) as [any, any[]];

    apiGroups = dictionaries?.groups ?? [];
    apiSubjects = dictionaries?.subjects ?? [];
    allRetakes = retakesRes ?? [];
} catch (error) {
    console.error('Failed to load public retakes', error);
}

const today = new Date().toISOString().split('T')[0];

const formattedRetakes = allRetakes.map((retake: any) => ({
    id: retake.id,
    groupUuid: retake.groupUuid,
    groupName:
        apiGroups.find((group: any) => group.uuid === retake.groupUuid)?.number || 'Неизвестная группа',
    subjectName: cleanSubjectName(
        retake.subjectName ||
        apiSubjects.find((subject: any) => subject.uuid === retake.subjectUuid)?.name ||
        'Неизвестная дисциплина'
    ),
    date: retake.date,
    timeSlots: retake.timeSlots,
    room: retake.roomUuid,
    link: retake.link,
    attemptNumber: retake.attemptNumber,
    teachers: retake.teachers || [],
}));
---

<Layout title="Расписание">
    <a
        slot="nav-actions"
        href="/login"
        class="inline-flex items-center justify-center h-10 px-4 rounded-2xl border border-slate-300/80 dark:border-white/10 bg-[var(--panel-bg-strong)] dark:bg-[var(--panel-muted)] text-slate-900 dark:text-white hover:border-slate-400 dark:hover:border-white/20 text-sm font-semibold transition"
    >
        Войти
    </a>

    <section class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8 sm:py-10 space-y-6">
        <MainScheduleBoard client:load groups={apiGroups} />

        <section class="space-y-3">
            <div class="px-1">
                <h2 class="text-2xl font-black tracking-tight text-slate-950 dark:text-white">Пересдачи</h2>
            </div>

            <StudentBoard
                client:load
                groups={apiGroups}
                retakes={formattedRetakes}
                today={today}
            />
        </section>
    </section>
</Layout>
