---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import StudentBoard from '../components/StudentBoard.vue';
import { db } from '../db';
import { retakes, retakeTeachers, teachersLocal } from '../db/schema';
import { RaspyxAPI } from '../lib/api-client';
import { eq, inArray } from 'drizzle-orm';
import { cleanSubjectName } from '../lib/subjectNorm';

let apiGroups = [];
let apiSubjects = [];
let allRetakes = [];
try {
    const [[gRes, sRes], dbRetakes] = await Promise.all([
        Promise.all([ RaspyxAPI.getGroups(), RaspyxAPI.getSubjects() ]),
        db.select().from(retakes)
    ]);
    if (gRes?.result) apiGroups = gRes.result;
    if (sRes?.result) apiSubjects = sRes.result;
    allRetakes = dbRetakes;
} catch (e) {}

const today = new Date().toISOString().split('T')[0];
const retakeIds = allRetakes.map(r => r.id);
let teachersMap: Record<number, {name: string, role: string}[]> = {};

if (retakeIds.length > 0) {
    const relations = await db
        .select({
            retakeId: retakeTeachers.retakeId,
            fullName: teachersLocal.fullName,
            role: retakeTeachers.role
        })
        .from(retakeTeachers)
        .leftJoin(teachersLocal, eq(retakeTeachers.teacherUuid, teachersLocal.uuid))
        .where(inArray(retakeTeachers.retakeId, retakeIds));

    relations.forEach(rel => {
        if (!teachersMap[rel.retakeId]) teachersMap[rel.retakeId] = [];
        if (rel.fullName && rel.role) {
            teachersMap[rel.retakeId].push({ name: rel.fullName, role: rel.role });
        }
    });
}

const formattedRetakes = allRetakes.map(r => ({
    id: r.id,
    groupUuid: r.groupUuid,
    groupName: apiGroups.find((g: any) => g.uuid === r.groupUuid)?.number || 'Неизвестная группа',
    subjectName: cleanSubjectName(apiSubjects.find((s: any) => s.uuid === r.subjectUuid)?.name || 'Неизвестный предмет'),
    date: r.date,
    timeSlots: r.timeSlots,
    room: r.roomUuid,
    link: r.link,
    attemptNumber: r.attemptNumber,
    teachers: teachersMap[r.id] || []
}));
---

<Layout title="Расписание пересдач — МПУ ФИТ">
    <a slot="nav-actions" href="/login"
        class="text-xs font-semibold text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white px-3.5 py-1.5 rounded-xl border border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600 hover:bg-white dark:hover:bg-slate-800 transition-all">
        Войти
    </a>

    <div class="min-h-[calc(100vh-4rem)]">
        <!-- Decorative gradient top -->
        <div class="relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-blue-50/80 via-violet-50/30 to-transparent dark:from-blue-950/30 dark:via-violet-950/10 dark:to-transparent pointer-events-none"></div>
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-br from-blue-400/8 to-violet-400/8 dark:from-blue-600/5 dark:to-violet-600/5 rounded-full blur-3xl pointer-events-none"></div>

            <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-4">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-blue-600 dark:text-blue-400 mb-2.5">Факультет информационных технологий</p>
                <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">
                    Расписание пересдач
                </h1>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-2">Московский Политехнический Университет</p>
            </div>
        </div>

        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            <StudentBoard client:load groups={apiGroups} retakes={formattedRetakes} today={today} />
        </div>
    </div>
</Layout>
