---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---
<Layout title="Страница не найдена">
    <div class="min-h-[85vh] flex flex-col items-center justify-center text-center p-4 relative overflow-hidden transition-colors">
        <div class="absolute inset-0 pointer-events-none opacity-70">
            <svg class="w-full h-full" viewBox="0 0 1600 900" preserveAspectRatio="none">
                <path d="M 150 640 C 420 480, 600 380, 850 240 S 1280 80, 1500 40" class="stroke-[rgba(90,122,165,0.18)] dark:stroke-[rgba(126,161,207,0.16)]" stroke-width="2" fill="none" stroke-dasharray="12 16" />
                <path d="M 340 840 C 510 690, 690 610, 930 520 S 1260 300, 1450 180" class="stroke-[rgba(90,122,165,0.1)] dark:stroke-[rgba(126,161,207,0.1)]" stroke-width="28" fill="none" stroke-linecap="round" />
            </svg>
        </div>

        <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center">
            <div class="flex items-center justify-center gap-3 mb-6">
                <span class="text-6xl md:text-8xl font-black text-slate-900 dark:text-white tracking-tighter">4</span>
                <div class="w-20 h-20 md:w-28 md:h-28 rounded-[28px] bg-[var(--panel-bg-strong)] border border-[var(--panel-border)] flex items-center justify-center overflow-hidden shadow-[var(--panel-shadow)]">
                    <img
                        src="/image/logo.png"
                        alt="Логотип университета"
                        class="w-12 h-12 md:w-16 md:h-16 object-contain"
                    />
                </div>
                <span class="text-6xl md:text-8xl font-black text-slate-900 dark:text-white tracking-tighter">4</span>
            </div>

            <h1 class="text-xl md:text-2xl text-slate-800 dark:text-slate-200 mb-3 font-semibold">
                Похоже, этой страницы нет в текущем маршруте.
            </h1>

            <p class="text-base text-slate-500 dark:text-slate-400 mb-10 max-w-lg mx-auto leading-relaxed">
                Возможно, ссылка устарела или адрес был введён с ошибкой. Вернитесь к расписанию и продолжите работу оттуда.
            </p>

            <button onclick="window.history.back()" class="px-8 py-3.5 bg-slate-900 hover:bg-slate-800 dark:bg-white dark:hover:bg-slate-200 text-white dark:text-slate-900 font-bold rounded-2xl shadow-[var(--panel-shadow)] transition-all">
                Вернуться назад
            </button>

            <div class="mt-16 p-6 academic-section text-sm text-slate-600 dark:text-slate-400 max-w-md mx-auto w-full">
                <p class="font-medium mb-3 text-slate-800 dark:text-slate-200">Связь с разработчиком</p>
                <a href="https://t.me/edducon" target="_blank" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-[var(--accent-soft)] text-[var(--accent-strong)] font-bold rounded-2xl hover:brightness-95 transition-colors w-full sm:w-auto">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.892-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                    Telegram: @edducon
                </a>
            </div>
        </div>
    </div>
</Layout>
