---
import AdminPanel from '../../components/AdminPanel.vue';
import Layout from '../../layouts/Layout.astro';
import { fetchBackendFromServer } from '../../lib/backend-api';
import { getPublicBackendApiUrl } from '../../lib/backend-auth';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect('/login');
}

if (user.role !== 'ADMIN') {
    return Astro.redirect('/dashboard');
}

let users = [];
let departments = [];
let teacherDirectory = [];
let positions = [];
let teachers = [];
let scheduleSnapshots = [];
let loadError = '';

try {
    const [usersRes, departmentsRes, teacherDirectoryRes, positionsRes, teachersRes, scheduleSnapshotsRes] = await Promise.all([
        fetchBackendFromServer('/users/', {}, Astro.request),
        fetchBackendFromServer('/departments/', {}, Astro.request),
        fetchBackendFromServer('/teacher-directory/', {}, Astro.request),
        fetchBackendFromServer('/positions/', {}, Astro.request),
        fetchBackendFromServer('/teachers/', {}, Astro.request),
        fetchBackendFromServer('/schedule-snapshots/', {}, Astro.request),
    ]);

    users = usersRes;
    departments = departmentsRes;
    teacherDirectory = teacherDirectoryRes;
    positions = positionsRes;
    teachers = teachersRes;
    scheduleSnapshots = scheduleSnapshotsRes;
} catch (error) {
    console.error('Failed to load admin data', error);
    loadError = error instanceof Error ? error.message : 'Не удалось загрузить данные админ-панели.';
}

const backendApiUrl = getPublicBackendApiUrl();
---

<Layout title="Администрирование">
    <Fragment slot="nav-actions">
        <a
            href="/dashboard"
            class="inline-flex items-center justify-center h-10 px-4 rounded-2xl border border-gray-300 dark:border-white/10 bg-white dark:bg-white/5 text-gray-700 dark:text-white/80 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-white/10 hover:border-gray-400 dark:hover:border-white/15 backdrop-blur-xl text-sm font-semibold transition-all duration-300 hover:-translate-y-0.5"
        >
            &larr; Рабочий кабинет
        </a>
    </Fragment>

    <AdminPanel
        client:load
        backendApiUrl={backendApiUrl}
        currentUserId={user.id}
        initialUsers={users}
        initialDepartments={departments}
        initialTeacherDirectory={teacherDirectory}
        initialPositions={positions}
        initialTeachers={teachers}
        initialScheduleSnapshots={scheduleSnapshots}
        initialLoadError={loadError}
    />
</Layout>
