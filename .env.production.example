APP_ENV=production
DEBUG=false

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rasp_db
POSTGRES_USER=rasp_user
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD

REDIS_HOST=redis
REDIS_PORT=6379

BACKEND_API_URL=/api
BACKEND_INTERNAL_API_URL=http://backend:8000/api

SESSION_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
SESSION_COOKIE_NAME=raspsystem_session
SESSION_MAX_AGE=604800
SESSION_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=

FRONTEND_ORIGINS=https://example.com
CSRF_TRUSTED_ORIGINS=https://example.com
API_DOCS_ENABLED=false
ALLOW_ORIGINLESS_UNSAFE_REQUESTS=false

LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
PASSWORD_CHANGE_RATE_LIMIT_ATTEMPTS=5
PASSWORD_CHANGE_RATE_LIMIT_WINDOW_SECONDS=600

RASPYX_USERNAME=CHANGE_THIS_USERNAME
RASPYX_PASSWORD=CHANGE_THIS_PASSWORD
